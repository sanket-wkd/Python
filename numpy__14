import numpy as np

print()
# Scalar operations - apply to ALL elements
prices = np.array([100, 250, 500, 1000, 2500])
print("Original prices  :", prices)
print("With 18% GST  :", prices * 1.18) 
print("After 10% disc :", prices * 0.9) 
print("Squared :", prices ** 2)

