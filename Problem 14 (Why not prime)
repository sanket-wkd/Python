# find the prime number also tell why it is not


n = int(input("Enter the number :"))

if n<=1 :
    print("This is not prime ")
    print("It is less then 1")
    exit()

for i in range(2,n):
    if(n % i == 0):
        print("THis is not prime number because of ",i)

        exit()  #stop program immediately

# If loop finishes, number is prime
print("This is a prime number")

