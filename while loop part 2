# This process repeats until number becomes less than or equal to 0.
     # factorial function
#while loop example

def fact(n):
    fact = 1
    
    if n==0 or n==1:
        return fact
    else:
        while(n>0):
            fact *=n
            n-=1
        return fact
        
n = int(input("Enter the number:"))
print(fact(n)

