marks = [ 77,97.64,85,55]

def grade(marks):
    if marks >= 90:
        return 'A'
    elif 80 <= marks <90:
        return 'B'
    elif 70 <= marks < 80:
        return 'C'
    elif 60 <= marks <70:
        return 'D'
    else:
        return 'F'
    
grades = map(grade,marks)
# grades = list (map(grade,marks))


print ("Exme Scores :",marks)
print("Grades:",next (grades))
print("Grades:",next (grades))
print ()
print ("By defalt print iteraton wise another wat is : ")
print()
print("Grades:",list (grades))# use lidt insted of next
#  or use list in front of map
print("Another way")

