
def factorial(x):
    fact = 1

    for i in range(1, x+1):
        fact *= i

    return fact



n = int(input("Enter the value of n :"))
r = int(input("Enter the value of r :"))

if r>n:
    print ("nCr does not exist")
else:
    ncr = factorial(n) // (factorial(r) * factorial(n - r))
    print("nCr =", ncr)

